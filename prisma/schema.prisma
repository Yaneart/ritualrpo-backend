generator client {
  provider     = "prisma-client"
  output       = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Услуги (организация похорон, кремация и т.д.)
model Service {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  fullText    String   @db.Text
  image       String
  price       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Категории товаров
model Category {
  id        String    @id @default(uuid())
  slug      String    @unique
  name      String
  order     Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Товары каталога
model Product {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  price       Int
  image       String
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Заявки с сайта
model Request {
  id        String   @id @default(uuid())
  type      String
  name      String
  phone     String
  email     String?
  message   String?  @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Администраторы
model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
