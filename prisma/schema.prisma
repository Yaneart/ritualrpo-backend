generator client {
  provider     = "prisma-client"
  output       = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Услуги (организация похорон, кремация и т.д.)
model Service {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  fullText    String   @db.Text
  image       String
  features    String[]
  price       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Категории товаров
model Category {
  id        String    @id @default(uuid())
  slug      String    @unique
  name      String
  order     Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Товары каталога
model Product {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  price       Int
  image       String
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Заявки с сайта
model Request {
  id        String   @id @default(uuid())
  type      String
  name      String
  phone     String
  email     String?
  message   String?  @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Администраторы
model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Отзывы клиентов
model Review {
  id         String   @id @default(uuid())
  name       String
  rating     Int
  text       String   @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Вопросы и ответы (FAQ)
model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Калькулятор: типы услуг (шаг 1)
model CalculatorServiceType {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  basePrice   Int
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Калькулятор: группа опций (обязательная или дополнительная)
model CalculatorGroup {
  id        String              @id @default(uuid())
  slug      String              @unique
  title     String
  type      CalculatorGroupType
  order     Int                 @default(0)
  options   CalculatorOption[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

// Калькулятор: опция внутри группы
model CalculatorOption {
  id          String          @id @default(uuid())
  slug        String          @unique
  title       String
  description String?
  price       Int
  order       Int             @default(0)
  groupId     String
  group       CalculatorGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

// О компании: статистика (10+ лет, 24/7 и т.д.)
model Stat {
  id        String   @id @default(uuid())
  value     String
  label     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// О компании: члены команды
model TeamMember {
  id        String   @id @default(uuid())
  name      String
  position  String
  photo     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Преимущества компании (секция "Почему мы")
model Advantage {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Настройки сайта (телефон, email, адрес и т.д.)
model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// Калькулятор: тип группы опций (required — обязательная, extra — дополнительная)
enum CalculatorGroupType {
  required
  extra
}
